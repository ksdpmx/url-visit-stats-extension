{
  "manifest_version": 2,
  "name": "URL Visit Stats",
  "version": "0.5.3",
  "description": "Show visit counts for the current URL and maintain lightweight local URL statistics.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "incognito": "not_allowed",
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_action": {
    "default_title": "URL Visit Stats",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "browser_style": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "url-visit-stats@local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
